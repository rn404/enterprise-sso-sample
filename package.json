{
  "name": "enterprise-sso-sample",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "autofix": "oxfmt && oxlint --fix",
    "source-guard": "oxfmt --check && oxlint && tsc",
    "runtime-guard": "echo 'no runtime checks yet' && exit 0",
    "precommit": "npm run autofix && npm run source-guard",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.0",
    "@node-saml/node-saml": "^5.1.0",
    "hono": "^4.12.15"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
